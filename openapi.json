      "EventStatus": {
        "description": "Status of the event lifecycle.\n\n- `archived`: The event is archived and no longer visible in listings.\n- `draft`: The event is still being edited and not yet published.\n- `live`: The event is published and accepting actions (e.g., ticket sales).\n- `started`: The event has begun.\n- `ended`: The event has ended.\n- `completed`: The event has concluded successfully and is finalized.\n- `canceled`: The event was canceled and is no longer active.",
        "enum": [
          "archived",
          "canceled",
          "completed",
          "draft",
          "ended",
          "live",
          "started"
        ],
        "title": "EventStatus",
        "type": "string"
      },

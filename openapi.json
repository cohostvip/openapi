      "CostBase": {
        "additionalProperties": false,
        "properties": {
          "cost": {
            "description": "A string representing a currency amount in the format `\"USD,1000\"` where:\n- `\"USD\"` is the 3-letter ISO currency code.\n- The number after the comma represents the value in **minor units** (e.g., cents for USD).\n\nFor example, `\"USD,1000\"` equals $10.00 (i.e., 1000 cents).",
            "pattern": "^\\\\w{3},\\\\d+$",
            "title": "cost",
            "type": "string"
          },
          "delivery": {
            "description": "A string representing a currency amount in the format `\"USD,1000\"` where:\n- `\"USD\"` is the 3-letter ISO currency code.\n- The number after the comma represents the value in **minor units** (e.g., cents for USD).\n\nFor example, `\"USD,1000\"` equals $10.00 (i.e., 1000 cents).",
            "pattern": "^\\\\w{3},\\\\d+$",
            "title": "delivery",
            "type": "string"
          },
          "fee": {
            "description": "A string representing a currency amount in the format `\"USD,1000\"` where:\n- `\"USD\"` is the 3-letter ISO currency code.\n- The number after the comma represents the value in **minor units** (e.g., cents for USD).\n\nFor example, `\"USD,1000\"` equals $10.00 (i.e., 1000 cents).",
            "pattern": "^\\\\w{3},\\\\d+$",
            "title": "fee",
            "type": "string"
          },
          "tax": {
            "description": "A string representing a currency amount in the format `\"USD,1000\"` where:\n- `\"USD\"` is the 3-letter ISO currency code.\n- The number after the comma represents the value in **minor units** (e.g., cents for USD).\n\nFor example, `\"USD,1000\"` equals $10.00 (i.e., 1000 cents).",
            "pattern": "^\\\\w{3},\\\\d+$",
            "title": "tax",
            "type": "string"
          }
        },
        "required": [
          "cost",
          "delivery",
          "fee",
          "tax"
        ],
        "title": "CostBase",
        "type": "object"
      },

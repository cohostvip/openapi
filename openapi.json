      "EqualOperator": {
        "description": "A set of comparison operators used for evaluating conditional expressions.\n\nSupported operators:\n- '==' (equal to)\n- '!=' (not equal to)\n- '<' (less than)\n- '<=' (less than or equal to)\n- '>' (greater than)\n- '>=' (greater than or equal to)",
        "enum": [
          "!=",
          "<",
          "<=",
          "==",
          ">",
          ">="
        ],
        "ignore": "",
        "title": "EqualOperator",
        "type": "string"
      },

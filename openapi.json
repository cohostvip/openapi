      "CostComponentCap": {
        "additionalProperties": false,
        "properties": {
          "op": {
            "const": "cap",
            "title": "op",
            "type": "string"
          },
          "type": {
            "enum": [
              "absolute",
              "percentage"
            ],
            "title": "type",
            "type": "string"
          },
          "value": {
            "description": "The value of the cap. If type is percentage, it is a percentage of the base value.\nIf type is absolute, it is an absolute value.\n\nAbsolute value is represented in the same denomination as the cost.\ni.e. if the cost is in cents, the absolute value should be in cents.\n\npercentage value is represented as a decimal.\nFor example, 10% is represented as 0.1.",
            "title": "value",
            "type": "number"
          }
        },
        "required": [
          "op",
          "type",
          "value"
        ],
        "title": "CostComponentCap",
        "type": "object"
      },
      "CostComponentRule": {
        "additionalProperties": false,
        "properties": {
          "conditions": {
            "description": "The rule will be applied to the cost component if the conditions are met.",
            "items": {
              "$ref": "#/components/schemas/CostComponentRuleCondition"
            },
            "title": "conditions",
            "type": "array"
          },
          "name": {
            "description": "Friendly name of the rule.",
            "title": "name",
            "type": "string"
          }
        },
        "required": [
          "conditions",
          "name"
        ],
        "title": "CostComponentRule",
        "type": "object"
      },
      "CostComponentRuleCondition": {
        "additionalProperties": false,
        "properties": {
          "eval": {
            "description": "evaluator, will define a function or endpoint to evaluate the condition.",
            "title": "eval",
            "type": "string"
          },
          "field": {
            "description": "The field to evaluate the condition against.\nFor example, \"item.price\" or \"order.total\".\nThe field should be a valid path to the field in the cost component base.",
            "title": "field",
            "type": "string"
          },
          "operator": {
            "$ref": "#/components/schemas/EqualOperator"
          },
          "value": {
            "description": "Can be a value such as number, currencyAmount, an ISO date string, etc...",
            "title": "value"
          }
        },
        "required": [
          "field",
          "operator",
          "value"
        ],
        "title": "CostComponentRuleCondition",
        "type": "object"
      },
      "CostOp": {
        "additionalProperties": false,
        "description": "Represents a cost operation to be applied in a pricing formula.",
        "properties": {
          "value": {
            "description": "The operand value used in the cost operation.\n\nThe unit should match the denomination of the cost.\nFor example, if cost is expressed in cents, this value should also be in cents.",
            "title": "value",
            "type": "number"
          }
        },
        "required": [
          "value"
        ],
        "title": "CostOp",
        "type": "object"
      },
      "CurrencyAmount": {
        "description": "A string representing a currency amount in the format `\"USD,1000\"` where:\n- `\"USD\"` is the 3-letter ISO currency code.\n- The number after the comma represents the value in **minor units** (e.g., cents for USD).\n\nFor example, `\"USD,1000\"` equals $10.00 (i.e., 1000 cents).",
